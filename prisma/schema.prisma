generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model CreatorPerformanceSource {
  id               String                @id @default(uuid()) @db.Uuid
  fullName         String                @map("full_name")
  revenueGenerated Decimal               @map("revenue_generated") @db.Decimal(12, 2)
  sourceDate       DateTime              @map("source_date") @db.Date
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  snapshots        LeaderboardSnapshot[]

  @@index([sourceDate], map: "creator_performance_source_source_date_idx")
  @@map("creator_performance_source")
}

model LeaderboardSnapshot {
  id               String                   @id @default(uuid()) @db.Uuid
  sourceId         String                   @map("source_id") @db.Uuid
  snapshotDate     DateTime                 @map("snapshot_date") @db.Date
  revenueGenerated Decimal                  @map("revenue_generated") @db.Decimal(12, 2)
  rankPosition     Int                      @map("rank_position")
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  source           CreatorPerformanceSource @relation(fields: [sourceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([snapshotDate, sourceId], map: "leaderboard_snapshot_date_source_id_key")
  @@index([snapshotDate, rankPosition], map: "leaderboard_snapshot_date_rank_idx")
  @@index([sourceId], map: "leaderboard_snapshot_source_id_idx")
  @@map("leaderboard_daily_snapshot")
}
